<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<!-- Quellcode-Ordner (Java-Dateien) -->
	<classpathentry kind="src" output="bin/main" path="src/main/java">
		<attributes>
			<attribute name="gradle_scope" value="main"/>
			<attribute name="gradle_used_by_scope" value="main,test"/>
		</attributes>
	</classpathentry>

	<!-- Ressourcen-Ordner (mixins.json, mods.toml, Texturen) -->
	<classpathentry kind="src" output="bin/main" path="src/main/resources">
		<attributes>
			<attribute name="gradle_scope" value="main"/>
			<attribute name="gradle_used_by_scope" value="main,test"/>
		</attributes>
	</classpathentry>

	<!-- Von Forge generierte Ressourcen (Daten-Generierung) -->
	<classpathentry kind="src" output="bin/main" path="src/generated/resources">
		<attributes>
			<attribute name="gradle_scope" value="main"/>
			<attribute name="gradle_used_by_scope" value="main,test"/>
		</attributes>
	</classpathentry>

	<!-- Test-Ordner (Können ignoriert werden, müssen aber strukturell da sein) -->
	<classpathentry kind="src" output="bin/test" path="src/test/java">
		<attributes>
			<attribute name="gradle_scope" value="test"/>
			<attribute name="gradle_used_by_scope" value="test"/>
			<attribute name="test" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="src" output="bin/test" path="src/test/resources">
		<attributes>
			<attribute name="gradle_scope" value="test"/>
			<attribute name="gradle_used_by_scope" value="test"/>
			<attribute name="test" value="true"/>
		</attributes>
	</classpathentry>

	<!-- JRE-Container: Zwingt Eclipse auf Java 17 für die 1.20.1 -->
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER/org.eclipse.jdt.internal.debug.ui.launcher.StandardVMType/JavaSE-17/"/>

	<!-- DAS HERZSTÜCK: Erlaubt Buildship (Gradle-Plugin), alle Minecraft/Forge-Jars dynamisch zu laden -->
	<classpathentry kind="con" path="org.eclipse.buildship.core.gradleclasspathcontainer"/>

	<!-- Annotation Processing (Wichtig für die Mixin-Generierung zur Compile-Zeit) -->
	<classpathentry kind="src" path="bin/generated-sources/annotations">
		<attributes>
			<attribute name="optional" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="src" output="bin/test" path="bin/generated-test-sources/annotations">
		<attributes>
			<attribute name="optional" value="true"/>
			<attribute name="test" value="true"/>
		</attributes>
	</classpathentry>

	<!-- Standard-Ausgabe-Verzeichnis für Eclipse -->
	<classpathentry kind="output" path="bin/default"/>
</classpath>