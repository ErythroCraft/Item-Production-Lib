package daripher.itemproduction.mixin.minecraft;

import daripher.itemproduction.ItemProductionLib;
import net.minecraft.world.Container;
import net.minecraft.world.entity.player.Player;
import net.minecraft.world.inventory.ResultContainer;
import net.minecraft.world.inventory.StonecutterMenu;
import net.minecraft.world.item.ItemStack;
import org.spongepowered.asm.mixin.Final;
import org.spongepowered.asm.mixin.Mixin;
import org.spongepowered.asm.mixin.Shadow;
import org.spongepowered.asm.mixin.Unique;
import org.spongepowered.asm.mixin.injection.At;
import org.spongepowered.asm.mixin.injection.Inject;
import org.spongepowered.asm.mixin.injection.callback.CallbackInfo;

@Mixin(StonecutterMenu.class)
public abstract class StonecutterMenuMixin {

  @Shadow
  @Final
  private ResultContainer resultContainer; // Der Ausgabe-Slot des Steinschneiders

  // Nutzen des Forge-Obfuskations-Helpers für das private Player-Feld der Vanilla-Klasse
  @Unique
  private Player itemProductionPlayer;

  @Unique
  private boolean itemProductionIsProcessing = false;

  /**
   * Klinkt sich am Ende (TAIL) der Slots-Aktualisierung im Steinschneider ein.
   * Berechnet die Skilltree-Boni, sobald ein neues Stein-Rezept ausgewählt wird.
   */
  @Inject(method = "slotsChanged", at = @At("TAIL"))
  private void onStonecutterSlotsChanged(Container container, CallbackInfo callbackInfo) {
    if (this.itemProductionIsProcessing) {
      return;
    }

    try {
      // Da das Player-Feld im StonecutterMenu geschützt ist, holen wir es uns sicher per Java-Reflection
      if (this.itemProductionPlayer == null) {
        java.lang.reflect.Field playerField;
        try {
          playerField = StonecutterMenu.class.getDeclaredField("f_40268_"); // 1.20.1 SRG player
        } catch (NoSuchFieldException e) {
          playerField = StonecutterMenu.class.getDeclaredField("player");
        }
        playerField.setAccessible(true);
        this.itemProductionPlayer = (Player) playerField.get(this);
      }

      // Modifikation strikt NUR auf der Serverseite erlauben!
      if (this.itemProductionPlayer != null && !this.itemProductionPlayer.level().isClientSide()) {
        ItemStack outputStack = this.resultContainer.getItem(0);

        if (!outputStack.isEmpty()) {
          try {
            this.itemProductionIsProcessing = true;

            // Das Item erhält den globalen Schutzstempel und wird durch deine Lib gejagt
            outputStack.getOrCreateTag().putBoolean("SkillTreeProcessed", true);
            ItemStack modifiedStack = ItemProductionLib.itemProduced(outputStack.copy(), this.itemProductionPlayer);

            // Das verbesserte Ergebnis sicher zurück in die GUI schreiben
            this.resultContainer.setItem(0, modifiedStack);
          } finally {
            this.itemProductionIsProcessing = false;
          }
        }
      }
    } catch (Exception ignored) {
      // NOSONAR: Schützt vor abweichenden Forge-Mapping-Builds
    }
  }
}
